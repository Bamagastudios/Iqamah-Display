# TV app environment. Copy to `.env` and adjust as needed.

# Unified MasjidTV feed (prayer times + announcements + events). Defaults to this if unset.
VITE_DISPLAY_FEED=https://tajweedusa.org/api/display

# Standalone prayer-times API (fallback / any-day lookups).
VITE_PRAYER_API=https://tajweedusa.org/api/prayer-times

# Supabase — branding/theme config layer (admin panel), added next.
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
